---
import Layout from '@/layouts/Layout.astro';
---

<Layout
  title="Blog de Salud Reumática | Artricenter — Artículos, Consejos y Recomendaciones"
  description="Artículos científicos, consejos de nutrición, ejercicios recomendados y mucho más sobre salud reumática. Artricenter, tu centro de reumatología en Ciudad de México."
  currentPage="/blog"
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "Blog",
    "name": "Blog de Salud Reumática - Artricenter",
    "description": "Blog de Artricenter con artículos sobre reumatismo, nutrición, salud y rehabilitación.",
    "url": "https://artricenter.com.mx/blog",
    "publisher": {
      "@type": "MedicalClinic",
      "name": "Artricenter",
      "url": "https://artricenter.com.mx"
    }
  }}
>
  <div class="max-w-7xl mx-auto px-4 py-12">
    <section class="mb-16">
      <h1 class="sr-only">Blog — Artricenter</h1>
      <h2 class="text-4xl md:text-5xl font-bold text-center mb-6" style="color: rgb(0, 83, 161)">Blog</h2>
      <div class="flex items-center justify-center gap-6 mb-12">
        <div class="h-1 w-40 rounded-full" style="background: linear-gradient(to right, transparent, rgb(0, 83, 161))"></div>
        <div class="flex gap-2">
          <div class="w-3 h-3 rounded-full animate-pulse" style="background-color: rgb(0, 83, 161)"></div>
          <div class="w-2 h-2 rounded-full" style="background-color: rgb(83, 175, 49)"></div>
          <div class="w-2 h-2 rounded-full" style="background-color: rgb(242, 144, 88)"></div>
        </div>
        <div class="h-1 w-40 rounded-full" style="background: linear-gradient(to left, transparent, rgb(242, 144, 88))"></div>
      </div>
    </section>

    <!-- Loading State -->
    <div id="loading-state" class="mb-20">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {Array.from({ length: 6 }).map(() => (
          <div class="rounded-2xl border-2 p-6 animate-pulse" style="border-color: rgba(0, 83, 161, 0.2); background: linear-gradient(to bottom right, rgba(0, 83, 161, 0.02), rgba(0, 83, 161, 0.05))">
            <div class="h-48 rounded-xl mb-4" style="background-color: rgba(0, 83, 161, 0.1)"></div>
            <div class="h-6 rounded mb-3 w-3/4" style="background-color: rgba(0, 83, 161, 0.15)"></div>
            <div class="h-4 rounded mb-2 w-full" style="background-color: rgba(0, 83, 161, 0.08)"></div>
            <div class="h-4 rounded mb-4 w-2/3" style="background-color: rgba(0, 83, 161, 0.08)"></div>
            <div class="flex gap-2 mb-4">
              <div class="h-6 rounded-full w-20" style="background-color: rgba(83, 175, 49, 0.15)"></div>
              <div class="h-6 rounded-full w-16" style="background-color: rgba(242, 144, 88, 0.15)"></div>
            </div>
            <div class="h-4 rounded w-1/3" style="background-color: rgba(0, 83, 161, 0.1)"></div>
          </div>
        ))}
      </div>
    </div>

    <!-- Error State -->
    <div id="error-state" class="hidden mb-20">
      <div class="max-w-2xl mx-auto text-center">
        <div class="mb-8">
          <svg class="mx-auto w-24 h-24" style="color: rgb(242, 144, 88)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
          </svg>
        </div>
        <h3 class="text-3xl md:text-4xl font-bold mb-4" style="color: rgb(0, 83, 161)">No pudimos cargar los artículos</h3>
        <p class="text-lg text-gray-600 leading-relaxed mb-8" id="error-message">
          Hubo un problema al conectar con el servidor. Por favor, intenta de nuevo más tarde.
        </p>
        <button
          id="retry-button"
          class="inline-flex items-center gap-3 text-white font-semibold px-8 py-4 rounded-xl shadow-lg hover:shadow-xl transition-all duration-200 transform hover:-translate-y-1 bg-[rgb(0,83,161)] hover:bg-[rgb(0,70,135)]"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
          </svg>
          <span>Intentar de nuevo</span>
        </button>
      </div>
    </div>

    <!-- Posts Grid -->
    <div id="posts-container" class="hidden mb-20">
      <div id="posts-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"></div>
    </div>

    <!-- Empty State -->
    <div id="empty-state" class="hidden mb-20">
      <div class="max-w-2xl mx-auto text-center">
        <div class="mb-8">
          <svg class="mx-auto w-24 h-24" style="color: rgb(83, 175, 49)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/>
          </svg>
        </div>
        <h3 class="text-3xl md:text-4xl font-bold mb-4" style="color: rgb(0, 83, 161)">Aún no hay artículos</h3>
        <p class="text-lg text-gray-600 leading-relaxed">
          Vuelve pronto para encontrar contenido sobre salud reumática.
        </p>
      </div>
    </div>

    <div class="flex items-center justify-center gap-6 my-16">
      <div class="h-1 w-40 rounded-full" style="background: linear-gradient(to right, transparent, rgb(0, 83, 161))"></div>
      <div class="flex gap-2">
        <div class="w-3 h-3 rounded-full animate-pulse" style="background-color: rgb(83, 175, 49)"></div>
        <div class="w-2 h-2 rounded-full" style="background-color: rgb(0, 83, 161)"></div>
        <div class="w-2 h-2 rounded-full" style="background-color: rgb(242, 144, 88)"></div>
      </div>
      <div class="h-1 w-40 rounded-full" style="background: linear-gradient(to left, transparent, rgb(242, 144, 88))"></div>
    </div>

    <section class="mb-16">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4" style="color: rgb(0, 83, 161)">Categorías</h2>
        <p class="text-lg text-gray-600">Explora nuestro contenido por temas</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-5xl mx-auto">
        <div class="rounded-2xl border-2 p-6 text-center transition-all duration-200 hover:shadow-lg relative overflow-hidden" style="border-color: rgba(0, 83, 161, 0.3); background: linear-gradient(to bottom right, rgba(0, 83, 161, 0.05), rgba(0, 83, 161, 0.1))">
          <div class="mb-4">
            <svg class="mx-auto w-12 h-12" style="color: rgb(0, 83, 161)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-4" style="color: rgb(0, 83, 161)">Reumatismo</h3>
          <div class="space-y-2">
            <span class="block text-sm text-gray-600 bg-white/70 rounded-lg px-3 py-1.5">Artrosis</span>
            <span class="block text-sm text-gray-600 bg-white/70 rounded-lg px-3 py-1.5">Artritis Reumatoide</span>
            <span class="block text-sm text-gray-600 bg-white/70 rounded-lg px-3 py-1.5">Fibromialgia</span>
          </div>
        </div>

        <div class="rounded-2xl border-2 p-6 text-center transition-all duration-200 hover:shadow-lg relative overflow-hidden" style="border-color: rgba(83, 175, 49, 0.3); background: linear-gradient(to bottom right, rgba(83, 175, 49, 0.05), rgba(83, 175, 49, 0.1))">
          <div class="mb-4">
            <svg class="mx-auto w-12 h-12" style="color: rgb(83, 175, 49)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8.25v-1.5m0 1.5c-1.355 0-2.697.056-4.024.166C6.845 8.51 6 9.473 6 10.608v2.513m6-4.871c1.355 0 2.697.056 4.024.166C17.155 8.51 18 9.473 18 10.608v2.513M15 8.25v-1.5m-6 1.5v-1.5m12 9.75l-1.5.75a3.354 3.354 0 01-3 0 3.354 3.354 0 00-3 0 3.354 3.354 0 01-3 0 3.354 3.354 0 00-3 0 3.354 3.354 0 01-3 0L3 16.5m15-3.379a48.474 48.474 0 00-6-.371c-2.032 0-4.034.126-6 .371m12 0c.39.049.777.102 1.163.16 1.07.16 1.837 1.094 1.837 2.175v5.169c0 .621-.504 1.125-1.125 1.125H4.125A1.125 1.125 0 013 20.625v-5.17c0-1.08.768-2.014 1.837-2.174A47.78 47.78 0 016 13.12M12.265 3.11a.375.375 0 11-.53 0L12 2.845l.265.265zm-3 0a.375.375 0 11-.53 0L9 2.845l.265.265zm6 0a.375.375 0 11-.53 0L15 2.845l.265.265z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-4" style="color: rgb(83, 175, 49)">Nutrición</h3>
          <div class="space-y-2">
            <span class="block text-sm text-gray-600 bg-white/70 rounded-lg px-3 py-1.5">Orientación</span>
            <span class="block text-sm text-gray-600 bg-white/70 rounded-lg px-3 py-1.5">Suplementos</span>
          </div>
        </div>

        <div class="rounded-2xl border-2 p-6 text-center transition-all duration-200 hover:shadow-lg relative overflow-hidden" style="border-color: rgba(242, 144, 88, 0.3); background: linear-gradient(to bottom right, rgba(242, 144, 88, 0.05), rgba(242, 144, 88, 0.1))">
          <div class="mb-4">
            <svg class="mx-auto w-12 h-12" style="color: rgb(242, 144, 88)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-4" style="color: rgb(242, 144, 88)">Salud</h3>
          <div class="space-y-2">
            <span class="block text-sm text-gray-600 bg-white/70 rounded-lg px-3 py-1.5">Educación</span>
            <span class="block text-sm text-gray-600 bg-white/70 rounded-lg px-3 py-1.5">Recomendaciones</span>
          </div>
        </div>

        <div class="rounded-2xl border-2 p-6 text-center transition-all duration-200 hover:shadow-lg relative overflow-hidden" style="border-color: rgba(0, 83, 161, 0.3); background: linear-gradient(to bottom right, rgba(0, 83, 161, 0.05), rgba(0, 83, 161, 0.1))">
          <div class="mb-4">
            <svg class="mx-auto w-12 h-12" style="color: rgb(0, 83, 161)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-4" style="color: rgb(0, 83, 161)">Rehabilitación</h3>
          <div class="space-y-2">
            <span class="block text-sm text-gray-600 bg-white/70 rounded-lg px-3 py-1.5">Ejercicios</span>
            <span class="block text-sm text-gray-600 bg-white/70 rounded-lg px-3 py-1.5">Terapia Física</span>
          </div>
        </div>
      </div>
    </section>
  </div>

  <script>
    import { getImageUrl, parseCategories } from '@/lib/blogApi';

    const loadingState = document.getElementById('loading-state');
    const errorState = document.getElementById('error-state');
    const postsContainer = document.getElementById('posts-container');
    const postsGrid = document.getElementById('posts-grid');
    const emptyState = document.getElementById('empty-state');
    const errorMessage = document.getElementById('error-message');
    const retryButton = document.getElementById('retry-button');

    function formatDate(dateString: string): string {
      const date = new Date(dateString);
      return date.toLocaleDateString('es-MX', {
        year: 'numeric',
        month: 'long',
        day: 'numeric'
      });
    }

    function showLoading() {
      loadingState?.classList.remove('hidden');
      errorState?.classList.add('hidden');
      postsContainer?.classList.add('hidden');
      emptyState?.classList.add('hidden');
    }

    function showError(message: string) {
      loadingState?.classList.add('hidden');
      errorState?.classList.remove('hidden');
      postsContainer?.classList.add('hidden');
      emptyState?.classList.add('hidden');
      if (errorMessage) {
        errorMessage.textContent = message;
      }
    }

    function showPosts() {
      loadingState?.classList.add('hidden');
      errorState?.classList.add('hidden');
      postsContainer?.classList.remove('hidden');
      emptyState?.classList.add('hidden');
    }

    function showEmpty() {
      loadingState?.classList.add('hidden');
      errorState?.classList.add('hidden');
      postsContainer?.classList.add('hidden');
      emptyState?.classList.remove('hidden');
    }

    function renderPosts(posts: any[]) {
      if (!postsGrid) return;

      if (posts.length === 0) {
        showEmpty();
        return;
      }

      postsGrid.innerHTML = posts.map(post => {
        const imageUrl = getImageUrl(post.featuredImage);
        const categories = parseCategories(post.categoriesJson || '[]');

        return `
          <article class="rounded-2xl border-2 overflow-hidden transition-all duration-200 hover:shadow-lg flex flex-col h-full" style="border-color: rgba(0, 83, 161, 0.2); background: linear-gradient(to bottom right, rgba(0, 83, 161, 0.02), rgba(0, 83, 161, 0.05))">
            ${imageUrl ? `
              <div class="relative h-48 overflow-hidden">
                <img
                  src="${imageUrl}"
                  alt="${post.title}"
                  class="w-full h-full object-cover transition-transform duration-300 hover:scale-105"
                  loading="lazy"
                />
              </div>
            ` : `
              <div class="h-48 flex items-center justify-center" style="background: linear-gradient(to bottom right, rgba(0, 83, 161, 0.05), rgba(0, 83, 161, 0.1))">
                <svg class="w-16 h-16" style="color: rgba(0, 83, 161, 0.2)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/>
                </svg>
              </div>
            `}
            <div class="p-6 flex flex-col flex-grow">
              <div class="flex flex-wrap gap-2 mb-3">
                ${categories.map((cat: string, i: number) => {
                  const colors = [
                    'background-color: rgb(0, 83, 161)',
                    'background-color: rgb(83, 175, 49)',
                    'background-color: rgb(242, 144, 88)'
                  ];
                  return `<span class="text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full text-white" style="${colors[i % colors.length]}">${cat}</span>`;
                }).join('')}
              </div>
              <h3 class="text-xl font-bold mb-3 line-clamp-2" style="color: rgb(0, 83, 161)">${post.title}</h3>
              <p class="text-gray-600 leading-relaxed mb-4 line-clamp-3 flex-grow">${post.excerpt || ''}</p>
              <div class="flex items-center justify-between pt-4 border-t" style="border-color: rgba(0, 83, 161, 0.1)">
                <span class="text-sm text-gray-500">${formatDate(post.publishedAt)}</span>
                <a
                  href="/blog/${post.slug}"
                  class="inline-flex items-center gap-2 text-sm font-semibold transition-colors hover:underline"
                  style="color: rgb(0, 83, 161)"
                >
                  Leer más
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                  </svg>
                </a>
              </div>
            </div>
          </article>
        `;
      }).join('');

      showPosts();
    }

    async function loadPosts() {
      showLoading();
      try {
        const API_URL = import.meta.env.PUBLIC_API_URL;
        const response = await fetch(`${API_URL}/api/blog/posts?page=1&pageSize=10`);
        if (!response.ok) {
          throw new Error(`Error ${response.status}: ${response.statusText}`);
        }
        const result = await response.json();
        if (!result?.status?.success) {
          throw new Error(result?.status?.message || 'Error al cargar los posts');
        }
        const posts = Array.isArray(result.data) ? result.data : [];
        const mappedPosts = posts.map((post: any) => ({
          ...post,
          featuredImage: post.featured_image || null,
          categoriesJson: post.categories_json || '[]',
          publishedAt: post.published_at || new Date().toISOString(),
          authorName: post.author_name || 'Artricenter',
          excerpt: post.excerpt || post.content?.substring(0, 200) || ''
        }));
        renderPosts(mappedPosts);
      } catch (error) {
        const message = error instanceof Error ? error.message : 'Error desconocido al cargar los artículos';
        showError(message);
      }
    }

    loadPosts();

    retryButton?.addEventListener('click', () => {
      loadPosts();
    });
  </script>
</Layout>
