---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Tratamiento - Artricenter" description="Tratamiento médico integral para enfermedades reumáticas" currentPage="tratamiento-medico-integral">
  <meta http-equiv="refresh" content="0;url=/tratamiento-medico-integral/" />
  <div class="flex flex-col items-center justify-center min-h-[60vh] gap-6 px-4">
    <div class="flex gap-1.5">
      <span class="w-2.5 h-2.5 bg-blue-600 rounded-full animate-bounce [animation-delay:-0.3s]"></span>
      <span class="w-2.5 h-2.5 bg-blue-600 rounded-full animate-bounce [animation-delay:-0.15s]"></span>
      <span class="w-2.5 h-2.5 bg-blue-600 rounded-full animate-bounce"></span>
    </div>
    <p class="text-lg text-gray-600">Redirigiendo...</p>
    <a href="/tratamiento-medico-integral/" class="text-blue-600 hover:text-blue-800 underline text-sm transition-colors">
      Si no eres redirigido automáticamente, haz clic aquí
    </a>
  </div>
  <script>
    window.location.href = '/tratamiento-medico-integral/';
  </script>
</Layout>
