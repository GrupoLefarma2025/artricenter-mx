---
import Layout from '@/layouts/Layout.astro';
---

<Layout
  title="Testimonios de Pacientes | Artricenter — Opiniones y Resultados Reales"
  description="Lee los testimonios y opiniones de pacientes de Artricenter. Resultados reales en el tratamiento de artrosis, artritis reumatoide y fibromialgia. Reseñas verificadas de Google."
  currentPage="testimonios"
>
  <div class="max-w-7xl mx-auto px-4 py-12">
    <div class="text-center py-24">
      <div class="inline-flex items-center justify-center w-24 h-24 rounded-full bg-blue-50 mb-8">
        <svg class="w-12 h-12 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
        </svg>
      </div>
      <h1 class="text-4xl md:text-5xl font-bold mb-6" style="color: rgb(0, 83, 161)">Sección en construcción</h1>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        Estamos trabajando para traerte los mejores testimonios de nuestros pacientes. Vuelve pronto.
      </p>
    </div>
  </div>
</Layout>
