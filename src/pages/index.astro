  <!-- Script: Carousel -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const track = document.getElementById('carousel-track');
      const slides = track ? track.querySelectorAll('.carousel-slide') : [];
      const dots = document.querySelectorAll('.carousel-dot');
      const prevBtn = document.querySelector('.carousel-prev');
      const nextBtn = document.querySelector('.carousel-next');
      const carousel = document.getElementById('hero-carousel');
      if (!track || dots.length === 0) return;

      let current = 0;
      const total = dots.length;

      function goTo(index) {
        current = ((index % total) + total) % total;
        track.style.transform = `translateX(-${current * 100}%)`;
        dots.forEach((d, i) => d.classList.toggle('active', i === current));
        // Re-trigger Ken Burns: removing then re-adding restarts the animation.
        slides.forEach((s, i) => s.classList.toggle('is-active', i === current));
      }

      prevBtn?.addEventListener('click', () => goTo(current - 1));
      nextBtn?.addEventListener('click', () => goTo(current + 1));
      dots.forEach((dot) => {
        dot.addEventListener('click', () => goTo(parseInt(dot.dataset.index)));
      });

      // Auto-advance, paused while the pointer rests on the carousel.
      let timer = setInterval(() => goTo(current + 1), 5000);
      carousel?.addEventListener('mouseenter', () => clearInterval(timer));
      carousel?.addEventListener('mouseleave', () => {
        timer = setInterval(() => goTo(current + 1), 5000);
      });
    });
  </script>

  <!-- Script: IntersectionObserver para animaciones de scroll -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const timelineContainer = document.querySelector('.timeline-container');
      const progressBar = document.getElementById('timeline-progress');
      const items = document.querySelectorAll('.timeline-item');

      if (!timelineContainer || !progressBar || items.length === 0) return;

      // ——— Animate cards and circles on scroll ———
      items.forEach((item) => {
        const side = item.getAttribute('data-side');
        const content = item.querySelector('.timeline-content');
        const circle = item.querySelector('.timeline-circle');

        if (content) {
          content.classList.add(side === 'left' ? 'reveal-left' : 'reveal-right');
        }
        if (circle) {
          circle.classList.add('reveal-center');
        }
      });

      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              // Animate stat bars inside this item
              const bars = entry.target.querySelectorAll('.timeline-stat-bar');
              bars.forEach((bar) => {
                const percent = bar.getAttribute('data-percent');
                setTimeout(() => {
                  bar.style.width = percent + '%';
                }, 300);
              });
            }
          });
        },
        { threshold: 0.2, rootMargin: '0px 0px -50px 0px' }
      );

      // Observe all animated elements
      document.querySelectorAll('.reveal-left, .reveal-right, .reveal-center').forEach((el) => {
        revealObserver.observe(el);
      });

      // ——— Animate progress line on scroll ———
      function updateProgressLine() {
        const rect = timelineContainer.getBoundingClientRect();
        const containerTop = rect.top;
        const containerHeight = rect.height;
        const viewportCenter = window.innerHeight / 2;

        // Calculate how far the user has scrolled through the timeline
        const scrolled = viewportCenter - containerTop;
        const progress = Math.max(0, Math.min(1, scrolled / containerHeight));

        progressBar.style.height = (progress * containerHeight) + 'px';
      }

      // Use scroll event with requestAnimationFrame for smooth updates
      let ticking = false;
      window.addEventListener('scroll', () => {
        if (!ticking) {
          window.requestAnimationFrame(() => {
            updateProgressLine();
            ticking = false;
          });
          ticking = true;
        }
      }, { passive: true });

      // Initial update
      updateProgressLine();
