---
import Layout from '@/layouts/Layout.astro';
---

<Layout
  title="Preguntas y Quejas | Artricenter — Centro de Reumatología en CDMX"
  description="Preguntas frecuentes sobre Artricenter: enfermedades que tratamos, costos, ubicaciones y horarios. También puedes enviar quejas y sugerencias. Contáctanos al 55 5989 0607."
  currentPage="preguntas-quejas"
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "name": "Preguntas Frecuentes - Artricenter",
    "description": "Preguntas frecuentes sobre Artricenter, clínica de reumatología en Ciudad de México.",
    "url": "https://artricenter.com.mx/preguntas_quejas",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "¿Qué enfermedades tratan?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "En Artricenter nos especializamos en el tratamiento de Osteoartrosis, Artritis Reumatoide y Fibromialgia, así como otras enfermedades reumáticas."
        }
      },
      {
        "@type": "Question",
        "name": "¿Cuánto cuesta la consulta de valoración?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "La consulta de valoración es sin costo. Agenda tu cita para una evaluación completa."
        }
      },
      {
        "@type": "Question",
        "name": "¿Dónde están ubicados?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Contamos con 3 sucursales: La Raza, Atizapán y Viaducto, en Ciudad de México."
        }
      },
      {
        "@type": "Question",
        "name": "¿Cuál es el horario de atención?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Lunes a viernes de 07:00 a 19:00 hrs, sábados de 07:00 a 18:00 hrs."
        }
      },
      {
        "@type": "Question",
        "name": "¿Cómo puedo agendar una cita?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Puedes agendar tu cita a través de WhatsApp al 55 5989 0607 o llamando al 55 1346 4000."
        }
      }
    ]
  }}
>
  <div class="max-w-7xl mx-auto px-4 py-12">
    <section id="preguntas-quejas" class="mb-16 scroll-mt-20">
      <div class="text-center mb-12">
        <h1 class="sr-only">Preguntas y Quejas — Artricenter</h1>
        <h2 class="text-4xl md:text-5xl font-bold text-blue-600 mb-6">Preguntas y Quejas</h2>
        <div class="flex items-center justify-center gap-6 mb-8">
          <div class="h-1 w-40 rounded-full" style="background: linear-gradient(to right, transparent, rgb(0, 83, 161))"></div>
          <div class="flex gap-2">
            <div class="w-3 h-3 rounded-full animate-pulse" style="background-color: rgb(0, 83, 161)"></div>
            <div class="w-2 h-2 rounded-full" style="background-color: rgb(83, 175, 49)"></div>
            <div class="w-2 h-2 rounded-full" style="background-color: rgb(242, 144, 88)"></div>
          </div>
          <div class="h-1 w-40 rounded-full" style="background: linear-gradient(to left, transparent, rgb(242, 144, 88))"></div>
        </div>
        <p class="text-lg text-gray-600 max-w-3xl mx-auto">
          Resolvemos tus dudas sobre nuestros servicios, horarios, ubicaciones y más.
        </p>
      </div>
    </section>

    <section id="preguntas-frecuentes" class="mb-16 scroll-mt-20">
      <h2 class="text-3xl md:text-4xl font-bold text-blue-600 text-center mb-12">Preguntas Frecuentes</h2>

      <div class="max-w-4xl mx-auto space-y-6">
        <div class="bg-white rounded-2xl shadow-xl p-8 border-2 border-blue-100 hover:border-blue-300 transition-all duration-300">
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-12 h-12 rounded-full flex items-center justify-center" style="background: linear-gradient(135deg, rgb(0, 83, 161), rgb(0, 110, 200));">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-bold text-gray-900 mb-3">¿Qué enfermedades tratan?</h3>
              <p class="text-gray-700 leading-relaxed">En Artricenter nos especializamos en el tratamiento de Osteoartrosis, Artritis Reumatoide y Fibromialgia, así como otras enfermedades reumáticas.</p>
            </div>
          </div>
        </div>

        <div class="bg-white rounded-2xl shadow-xl p-8 border-2 border-green-100 hover:border-green-300 transition-all duration-300">
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-12 h-12 rounded-full flex items-center justify-center" style="background: linear-gradient(135deg, rgb(83, 175, 49), rgb(100, 200, 60));">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-bold text-gray-900 mb-3">¿Cuánto cuesta la consulta de valoración?</h3>
              <p class="text-gray-700 leading-relaxed">La consulta de valoración es sin costo. Agenda tu cita para una evaluación completa.</p>
            </div>
          </div>
        </div>

        <div class="bg-white rounded-2xl shadow-xl p-8 border-2 border-orange-100 hover:border-orange-300 transition-all duration-300">
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-12 h-12 rounded-full flex items-center justify-center" style="background: linear-gradient(135deg, rgb(242, 144, 88), rgb(255, 170, 120));">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-bold text-gray-900 mb-3">¿Dónde están ubicados?</h3>
              <p class="text-gray-700 leading-relaxed">Contamos con 3 sucursales: La Raza, Atizapán y Viaducto, en Ciudad de México.</p>
            </div>
          </div>
        </div>

        <div class="bg-white rounded-2xl shadow-xl p-8 border-2 border-blue-100 hover:border-blue-300 transition-all duration-300">
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-12 h-12 rounded-full flex items-center justify-center" style="background: linear-gradient(135deg, rgb(0, 83, 161), rgb(0, 110, 200));">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-bold text-gray-900 mb-3">¿Cuál es el horario de atención?</h3>
              <p class="text-gray-700 leading-relaxed">Lunes a viernes de 07:00 a 19:00 hrs, sábados de 07:00 a 18:00 hrs.</p>
            </div>
          </div>
        </div>

        <div class="bg-white rounded-2xl shadow-xl p-8 border-2 border-green-100 hover:border-green-300 transition-all duration-300">
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-12 h-12 rounded-full flex items-center justify-center" style="background: linear-gradient(135deg, rgb(83, 175, 49), rgb(100, 200, 60));">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-bold text-gray-900 mb-3">¿Cómo puedo agendar una cita?</h3>
              <p class="text-gray-700 leading-relaxed">Puedes agendar tu cita a través de WhatsApp al 55 5989 0607 o llamando al 55 1346 4000.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="flex items-center justify-center gap-6 my-16">
      <div class="h-1 w-40 rounded-full" style="background: linear-gradient(to right, transparent, rgb(0, 83, 161))"></div>
      <div class="flex gap-2">
        <div class="w-3 h-3 rounded-full animate-pulse" style="background-color: rgb(0, 83, 161)"></div>
        <div class="w-2 h-2 rounded-full" style="background-color: rgb(83, 175, 49)"></div>
        <div class="w-2 h-2 rounded-full" style="background-color: rgb(242, 144, 88)"></div>
      </div>
      <div class="h-1 w-40 rounded-full" style="background: linear-gradient(to left, transparent, rgb(242, 144, 88))"></div>
    </div>

    <section id="quejas-sugerencias" class="mb-16 scroll-mt-20">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-green-600 mb-6">Quejas y Sugerencias</h2>
        <div class="flex items-center justify-center gap-6 mb-8">
          <div class="h-1 w-40 rounded-full" style="background: linear-gradient(to right, transparent, rgb(83, 175, 49))"></div>
          <div class="flex gap-2">
            <div class="w-3 h-3 rounded-full animate-pulse" style="background-color: rgb(83, 175, 49)"></div>
            <div class="w-2 h-2 rounded-full" style="background-color: rgb(0, 83, 161)"></div>
            <div class="w-2 h-2 rounded-full" style="background-color: rgb(242, 144, 88)"></div>
          </div>
          <div class="h-1 w-40 rounded-full" style="background: linear-gradient(to left, transparent, rgb(242, 144, 88))"></div>
        </div>
      </div>

      <div class="max-w-3xl mx-auto">
        <div class="bg-white rounded-2xl shadow-2xl p-8 md:p-12 border-2 border-green-200">
          <div class="text-center mb-8">
            <p class="text-lg text-gray-700 leading-relaxed">
              En <strong class="text-green-600">Artricenter</strong> nos importa tu experiencia. Si tienes alguna queja, pregunta o sugerencia, no dudes en comunicarte con nosotros.
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
            <a href="https://artricenter.com.mx/contactanos/" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-4 p-5 rounded-xl border-2 hover:shadow-lg transition-all duration-200" style="background: linear-gradient(to bottom right, rgba(83, 175, 49, 0.1), rgba(83, 175, 49, 0.2)); border-color: rgba(83, 175, 49, 0.3);">
              <div class="flex-shrink-0 w-12 h-12 rounded-full flex items-center justify-center group-hover:scale-110 transition-transform" style="background-color: rgb(83, 175, 49)">
                <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-wide" style="color: rgb(83, 175, 49)">WhatsApp</p>
                <p class="text-gray-900 font-bold text-lg">55 5989 0607</p>
              </div>
            </a>

            <a href="tel:5513464000" class="group flex items-center gap-4 p-5 rounded-xl border-2 hover:shadow-lg transition-all duration-200" style="background: linear-gradient(to bottom right, rgba(0, 83, 161, 0.1), rgba(0, 83, 161, 0.2)); border-color: rgba(0, 83, 161, 0.3);">
              <div class="flex-shrink-0 w-12 h-12 rounded-full flex items-center justify-center group-hover:scale-110 transition-transform" style="background-color: rgb(0, 83, 161)">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-wide" style="color: rgb(0, 83, 161)">Teléfono</p>
                <p class="text-gray-900 font-bold text-lg">55 1346 4000</p>
              </div>
            </a>
          </div>

          <div class="text-center">
            <p class="text-gray-600 mb-6">También puedes enviarnos un mensaje directamente:</p>
            <a
              href="/contactanos"
              class="inline-flex items-center gap-2 text-white font-semibold px-8 py-4 rounded-lg shadow-lg hover:shadow-xl transition-all duration-200"
              style="background-color: rgb(0, 83, 161)"
              onmouseenter="this.style.backgroundColor='rgb(0, 70, 135)'"
              onmouseleave="this.style.backgroundColor='rgb(0, 83, 161)'"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
              </svg>
              <span>Ir al formulario de contacto</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <div class="flex items-center justify-center gap-6 my-16">
      <div class="h-1 w-40 rounded-full" style="background: linear-gradient(to right, transparent, rgb(242, 144, 88))"></div>
      <div class="flex gap-2">
        <div class="w-3 h-3 rounded-full animate-pulse" style="background-color: rgb(242, 144, 88)"></div>
        <div class="w-2 h-2 rounded-full" style="background-color: rgb(0, 83, 161)"></div>
        <div class="w-2 h-2 rounded-full" style="background-color: rgb(83, 175, 49)"></div>
      </div>
      <div class="h-1 w-40 rounded-full" style="background: linear-gradient(to left, transparent, rgb(0, 83, 161))"></div>
    </div>

    <section id="cta" class="mb-16 scroll-mt-20">
      <div class="text-center">
        <div class="inline-block bg-white rounded-2xl shadow-xl p-8 md:p-12 border-2 border-blue-200">
          <p class="text-2xl md:text-3xl font-bold text-gray-900 mb-2">¿Aún tienes dudas?</p>
          <p class="text-gray-600 mb-8">Estamos aquí para ayudarte. Contáctanos o conoce más sobre nuestro programa.</p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a
              href="/contactanos"
              class="inline-flex items-center gap-2 text-white font-bold py-3 px-8 rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 hover:scale-105"
              style="background-color: rgb(0, 83, 161)"
              onmouseenter="this.style.backgroundColor='rgb(0, 70, 135)'"
              onmouseleave="this.style.backgroundColor='rgb(0, 83, 161)'"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
              </svg>
              <span>Contáctanos</span>
            </a>
            <a
              href="/club-vida-y-salud"
              class="inline-flex items-center gap-2 bg-gradient-to-r hover:from-green-600 hover:to-green-700 text-white font-bold py-3 px-8 rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 hover:scale-105"
              style="background-color: rgb(83, 175, 49)"
              onmouseenter="this.style.backgroundColor='rgb(70, 155, 40)'"
              onmouseleave="this.style.backgroundColor='rgb(83, 175, 49)'"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
              </svg>
              <span>Conoce nuestro programa</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>
