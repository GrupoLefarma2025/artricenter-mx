<style>
/* Botón animado Preguntas y sugerencias -.btn-footer-preguntas */
.btn-footer-preguntas,
.btn-footer-preguntas *,
.btn-footer-preguntas :after,
.btn-footer-preguntas :before,
.btn-footer-preguntas:after,
.btn-footer-preguntas:before {
  border: 0 solid;
  box-sizing: border-box;
}

.btn-footer-preguntas {
  -webkit-tap-highlight-color: transparent;
  -webkit-appearance: button;
  background-color: rgb(0, 83, 161);
  background-image: none;
  color: #fff;
  cursor: pointer;
  font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
    Segoe UI, Roboto, Helvetica Neue, Arial, Noto Sans, sans-serif;
  font-size: 100%;
  font-weight: 900;
  line-height: 1.5;
  margin: 0;
  -webkit-mask-image: -webkit-radial-gradient(#000, #fff);
  padding: 0;
  text-transform: uppercase;
}

.btn-footer-preguntas:disabled {
  cursor: default;
}

.btn-footer-preguntas:-moz-focusring {
  outline: auto;
}

.btn-footer-preguntas svg {
  display: block;
  vertical-align: middle;
}

.btn-footer-preguntas [hidden] {
  display: none;
}

.btn-footer-preguntas {
  border-radius: 99rem;
  border-width: 2px;
  padding: 0.6rem 1.5rem;
  z-index: 0;
  text-decoration: none;
}

.btn-footer-preguntas,
.btn-footer-preguntas .text-container {
  overflow: hidden;
  position: relative;
}

.btn-footer-preguntas .text-container {
  display: block;
  mix-blend-mode: difference;
}

.btn-footer-preguntas .text {
  display: block;
  position: relative;
}

.btn-footer-preguntas:hover .text {
  -webkit-animation: move-up-alternate 0.3s forwards;
  animation: move-up-alternate 0.3s forwards;
}

@-webkit-keyframes move-up-alternate {
  0% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(80%);
  }
  51% {
    transform: translateY(-80%);
  }
  to {
    transform: translateY(0);
  }
}

@keyframes move-up-alternate {
  0% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(80%);
  }
  51% {
    transform: translateY(-80%);
  }
  to {
    transform: translateY(0);
  }
}

.btn-footer-preguntas:after,
.btn-footer-preguntas:before {
  --skew: 0.2;
  background: #fff;
  content: "";
  display: block;
  height: 102%;
  left: calc(-50% - 50% * var(--skew));
  pointer-events: none;
  position: absolute;
  top: -104%;
  transform: skew(calc(150deg * var(--skew))) translateY(var(--progress, 0));
  transition: transform 0.2s ease;
  width: 100%;
}

.btn-footer-preguntas:after {
  --progress: 0%;
  left: calc(50% + 50% * var(--skew));
  top: 102%;
  z-index: -1;
}

.btn-footer-preguntas:hover:before {
  --progress: 100%;
}

.btn-footer-preguntas:hover:after {
  --progress: -102%;
}
</style>

