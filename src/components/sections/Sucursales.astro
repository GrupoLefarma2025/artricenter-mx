---
import { branches } from '@/data/branches';
---

<!-- Sucursales Section -->
<section id="sucursales" class="py-16 bg-gradient-to-br from-blue-50 via-white to-green-50">
  <div class="max-w-7xl mx-auto px-4">
    <!-- Header -->
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-blue-600 mb-4">Nuestras Sucursales</h2>
      <p class="text-gray-600 text-lg max-w-2xl mx-auto">
        Visítanos en cualquiera de nuestras 3 ubicaciones en Ciudad de México y Estado de México
      </p>
    </div>

    <!-- Branches Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {branches.map((branch, index) => {
        // Colores específicos por sucursal
        const branchColors = {
          0: { primary: 'rgb(0, 83, 161)', hover: 'rgba(0, 83, 161, 0.1)', name: 'La Raza' },
          1: { primary: 'rgb(83, 175, 49)', hover: 'rgba(83, 175, 49, 0.1)', name: 'Atizapán' },
          2: { primary: 'rgb(242, 144, 88)', hover: 'rgba(242, 144, 88, 0.1)', name: 'Viaducto' }
        };
        const colors = branchColors[index];

        return (
        <div
          class:list={[
            "group relative bg-white rounded-3xl shadow-xl hover:shadow-2xl transition-all duration-500 overflow-hidden border-2",
            "hover:-translate-y-2"
          ]}
          style={`border-color: ${colors.primary}`}
        >
          <!-- Gradient Background Overlay -->
          <div
            class="absolute inset-0 bg-gradient-to-br opacity-0 group-hover:opacity-100 transition-opacity duration-500"
            style={`background: linear-gradient(to bottom right, ${colors.hover} 0%, transparent 50%, ${colors.hover} 100%)`}
          ></div>

          <!-- Content -->
          <div class="relative p-8">
            <!-- Logo -->
            <div class="flex justify-center mb-6">
              <div class="relative w-32 h-32 bg-white rounded-2xl shadow-lg flex items-center justify-center p-4 group-hover:scale-110 transition-transform duration-300">
                <img
                  src={branch.logo}
                  alt={`Artricenter ${branch.name}`}
                  class="w-full h-full object-contain"
                />
                <!-- Shine Effect -->
                <div class="absolute inset-0 rounded-2xl bg-gradient-to-tr from-transparent via-white/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
              </div>
            </div>

            <!-- Branch Name -->
            <h3 class="text-2xl font-bold text-center mb-4" style={`color: ${colors.primary}`}>
              Artricenter {branch.name}
            </h3>

            <!-- Location Icon & Address -->
            <div class="space-y-4 mb-6">
              <div class="flex items-start gap-3">
                <div class="flex-shrink-0 w-10 h-10 rounded-full flex items-center justify-center" style={`background-color: ${colors.hover}`}>
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" style={`color: ${colors.primary}`}>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-sm text-gray-700 leading-relaxed" set:html={branch.address}></p>
                </div>
              </div>

              <!-- Phone -->
              <div class="flex items-center gap-3">
                <div class="flex-shrink-0 w-10 h-10 rounded-full flex items-center justify-center" style={`background-color: ${colors.hover}`}>
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" style={`color: ${colors.primary}`}>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                  </svg>
                </div>
                <a href={`tel:${branch.phone.replace(/\s/g, '')}`} class="text-gray-700 font-semibold hover:opacity-80 transition-opacity" style={`color: ${colors.primary}`}>
                  {branch.phone}
                </a>
              </div>
            </div>

            <!-- Google Maps Button -->
            <a
              href={branch.mapsUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center gap-2 w-full text-white font-semibold py-3 px-6 rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 group-hover:scale-105"
              style={`background: linear-gradient(to right, ${colors.primary}, ${colors.primary})`}
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
              </svg>
              <span>Ver en Google Maps</span>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
            </a>
          </div>

          <!-- Decorative Elements -->
          <div class="absolute top-4 right-4 w-8 h-8 rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-300 animate-pulse" style={`background: ${colors.primary}`}></div>
          <div class="absolute bottom-4 left-4 w-4 h-4 rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-300 delay-100" style={`background: ${colors.primary}; opacity: 0.6`}></div>
        </div>
        );
      })}
    </div>

    <!-- CTA Section -->
    <div class="mt-16 text-center">
      <div class="inline-block bg-white rounded-2xl shadow-xl p-8 border-2 border-blue-200">
        <p class="text-xl font-bold text-gray-900 mb-2">¿Necesitas ayuda para encontrar tu sucursal más cercana?</p>
        <p class="text-gray-600 mb-6">Llámanos y con gusto te orientamos</p>
        <a
          href="tel:5559890607"
          class="inline-flex items-center gap-2 bg-gradient-to-r from-blue-600 to-green-600 hover:from-blue-700 hover:to-green-700 text-white font-bold py-3 px-8 rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 hover:scale-105"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          <span>55 5989 0607</span>
        </a>
      </div>
    </div>
  </div>
</section>
